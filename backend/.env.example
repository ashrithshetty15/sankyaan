# Backend Environment Configuration

# Server Port
PORT=5000

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Tables
DYNAMODB_STOCKS_TABLE=stocks
DYNAMODB_FUNDS_TABLE=mutual_funds

# Environment
NODE_ENV=development

# Newsletter / Email (Nodemailer SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=contact@sankyaan.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Sankyaan <contact@sankyaan.com>
NEWSLETTER_SECRET=your_strong_secret_here
BACKEND_URL=https://sankyaan-production.up.railway.app
